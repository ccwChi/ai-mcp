# ----------------------------------------------------
# AI-MCP 環境變數設定檔 (Environment Variables)
# 請將此檔案複製一份並重新命名為 `.env`，然後填入您的真實 Key
# ----------------------------------------------------

# ====================================================
# Google Gemini API
# 取得方式: 前往 https://aistudio.google.com/app/apikey (Google AI Studio)
# 登入你的 Google 帳號後，點擊 "Create API key" 即可產生。
# ====================================================

# 付費版 API Key (綁定 $10 優惠卷的帳號所建立的 Key)
GEMINI_PAID_API_KEY="your_paid_api_key_here"

# 免費版 API Key (當預算用滿，或是付費 Key 失敗時，自動降級使用的備用 Key)
# ※ 如果您只有一個帳號，這兩個欄位也可以填入相同的 Key
GEMINI_FREE_API_KEY="your_free_api_key_here"

# 設定預算上限限制 (單位: 美元)
# (系統會在本地計算每次請求的 Token 數量並估算花費，一但花費超過此數字就會自動將後續請求切換為免費方案)
GEMINI_BUDGET_LIMIT="10.0"

# ====================================================
# Telegram API
# ====================================================

# Telegram 機器人 Token (Bot Token)
# 取得方式: 
# 1. 在 Telegram App 內搜尋 `@BotFather`，開啟與他的對話
# 2. 輸入 `/newbot` 指令來建立新的機器人，並依照指示設定名稱與 Username
# 3. 完成後，BotFather 會回傳一串 HTTP API Token (例如: 123456789:ABCDefGHIJKlm...)
TELEGRAM_BOT_TOKEN="your_telegram_bot_token"

# Telegram 聊天室 ID (Chat ID) - 用來指定 bot 要把訊息傳給誰
# 取得方式: 
# 1. 若要傳給自己: 在 Telegram 搜尋 `@userinfobot` 或 `@getmyid_bot`，它會立刻回覆您的 User ID (純數字)
# 2. 若要傳到群組: 將剛建立的 Bot 加入群組並發送一則訊息，接著透過瀏覽器訪問: `https://api.telegram.org/bot<你的BOT_TOKEN>/getUpdates`，在 JSON 回傳值中尋找 `chat` 裡面的 `id` (群組 ID 通常以負號開頭，如 -100xxxxx)。
TELEGRAM_CHAT_ID="your_telegram_chat_id"

# ====================================================
# Notion API
# ====================================================

# Notion 內部整合 Token (Internal Integration Token)
# 取得方式:
# 1. 使用電腦瀏覽器前往 Notion 開發者平台: https://www.notion.so/my-integrations
# 2. 點擊 "New integration" (新增整合)
# 3. 填寫名稱與選擇對應的 Workspace 後儲存。
# 4. 在左側選單的 "Secrets" 頁面中，即可看到 Internal Integration Secret，點擊 Copy 複製 (通常以 secret_ 開頭)
NOTION_API_KEY="secret_your_notion_api_key"

# Notion 資料庫 ID (Database ID) - 用來指定你要寫入或讀取的資料表
# 取得方式:
# 1. 在您的 Notion 裡建立一個 Database (請確保它是 Full page，亦即有自己獨立的 URL)
# 2. 【最重要的一步】: 點擊資料庫頁面右上角的 "..." (More) 按鈕 -> 點選 "Connections" -> "Connect to" -> 找到並加入您剛剛建立的 Integration！(否則 API 會回傳權限不足 NotFound)
# 3. 從瀏覽器網址列複製 ID，格式如: `https://www.notion.so/您的Workspace名稱/<這個32字元亂碼就是Database_ID>?v=...`
#    (請只複製問號 `?` 前面那段由英數組成的 32 字元字串)
NOTION_DATABASE_ID="your_notion_database_id_here"
